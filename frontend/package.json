{
  "name": "open-aui",
  "version": "0.1.8",
  "private": true,
  "description": "Open AUI Electron 桌面应用",
  "license": "Apache-2.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "kill-ports": "node scripts/kill-ports.js",
    "_install-backend": "cd ../backend && npm install --omit=dev && cd ../frontend",
    "gen:icon": "node scripts/generate-icon.js",
    "electron:dev": "node scripts/kill-ports.js && npm run gen:icon && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && node scripts/ensure-icon-256.js && node scripts/prepare-package.js && npm run _install-backend && electron-builder",
    "embed-icon": "node scripts/embed-icon.js",
    "electron:build:portable": "npm run electron:build -- --win portable",
    "pack": "vite build && node scripts/prepare-package.js && npm run _install-backend && electron-builder --dir"
  },
  "dependencies": {
    "@nut-tree/nut-js": "^4.2.0",
    "@rollup/rollup-win32-x64-msvc": "^4.59.0",
    "@xyflow/react": "^12.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "robotjs": "^0.7.0",
    "screenshot-desktop": "^1.15.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.28.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "ico-to-png": "^0.2.2",
    "png-to-ico": "^2.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.49",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.16",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "afterPack": "./scripts/embed-icon-hook.js",
    "productName": "Open AUI",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist-app/**",
      "electron/**",
      "build/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/node",
        "to": "node",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "dist-app/images/icon/icon256.ico",
      "target": [
        "dir"
      ],
      "sign": null
    }
  }
}
